{
  "name": "genesis-copilot-orion-kernel",
  "displayName": "Genesis Copilot Orion Kernel",
  "description": "Sovereign AI coding agent with deterministic K=3.2 reasoning, E.I.R.A. monitoring, and EU AI Act audit trail. Powered by Qwen3-235B via OpenRouter — free to use.",
  "version": "0.14.4",
  "publisher": "Alvoradozerouno",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alvoradozerouno/qwen-code4EIRA.git",
    "directory": "packages/vscode-ide-companion"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "LICENSE",
  "preview": false,
  "categories": [
    "AI",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "orion",
    "genesis",
    "eira",
    "qwen",
    "qwen3",
    "openrouter",
    "ai agent",
    "coding agent",
    "agentic",
    "deterministic",
    "eu ai act",
    "audit trail",
    "cursor",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:qwen-code.chatView.sidebar",
    "onView:qwen-code.chatView.secondary",
    "onCommand:qwen-code.openChat",
    "onCommand:qwen-code.focusChat",
    "onCommand:qwen-code.newConversation",
    "onCommand:qwen-code.showLogs"
  ],
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": "**/.qwen/settings.json",
        "url": "./schemas/settings.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qwen-code-sidebar",
          "title": "Orion Kernel",
          "icon": "assets/sidebar-icon.svg",
          "when": "!qwen-code:supportsSecondarySidebar"
        }
      ],
      "secondarySidebar": [
        {
          "id": "qwen-code-secondary",
          "title": "Orion Kernel",
          "icon": "assets/sidebar-icon.svg",
          "when": "qwen-code:supportsSecondarySidebar"
        }
      ]
    },
    "views": {
      "qwen-code-sidebar": [
        {
          "type": "webview",
          "id": "qwen-code.chatView.sidebar",
          "name": "Orion Kernel",
          "icon": "assets/sidebar-icon.svg",
          "when": "!qwen-code:supportsSecondarySidebar"
        }
      ],
      "qwen-code-secondary": [
        {
          "type": "webview",
          "id": "qwen-code.chatView.secondary",
          "name": "Orion Kernel",
          "icon": "assets/sidebar-icon.svg",
          "when": "qwen-code:supportsSecondarySidebar"
        }
      ]
    },
    "languages": [
      {
        "id": "qwen-diff-editable"
      }
    ],
    "commands": [
      {
        "command": "qwen.diff.accept",
        "title": "Orion Kernel: Accept Current Diff",
        "icon": "$(check)"
      },
      {
        "command": "qwen.diff.cancel",
        "title": "Orion Kernel: Close Diff Editor",
        "icon": "$(close)"
      },
      {
        "command": "qwen-code.runQwenCode",
        "title": "Orion Kernel: Run"
      },
      {
        "command": "qwen-code.showNotices",
        "title": "Orion Kernel: View Third-Party Notices"
      },
      {
        "command": "qwen-code.openChat",
        "title": "Orion Kernel: Open",
        "icon": "./assets/icon.png"
      },
      {
        "command": "qwen-code.login",
        "title": "Orion Kernel: Login"
      },
      {
        "command": "qwen-code.focusChat",
        "title": "Orion Kernel: Focus Chat View"
      },
      {
        "command": "qwen-code.newConversation",
        "title": "Orion Kernel: New Conversation"
      },
      {
        "command": "qwen-code.showLogs",
        "title": "Orion Kernel: Show Logs"
      },
      {
        "command": "qwen-code.showOrionStatus",
        "title": "Orion Kernel: Show E.I.R.A. Status (Φ / K)"
      },
      {
        "command": "qwen-code.exportAuditReport",
        "title": "Orion Kernel: Export EU AI Act Audit Report"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "qwen.diff.accept",
          "when": "qwen.diff.isVisible"
        },
        {
          "command": "qwen.diff.cancel",
          "when": "qwen.diff.isVisible"
        },
        {
          "command": "qwen-code.login",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "qwen.diff.accept",
          "when": "qwen.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "qwen.diff.cancel",
          "when": "qwen.diff.isVisible",
          "group": "navigation"
        },
        {
          "command": "qwen-code.openChat",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "qwen.diff.accept",
        "key": "ctrl+s",
        "when": "qwen.diff.isVisible"
      },
      {
        "command": "qwen.diff.accept",
        "key": "cmd+s",
        "when": "qwen.diff.isVisible"
      },
      {
        "command": "qwen-code.focusChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "Genesis Orion Settings",
      "properties": {
        "genesis.orion.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "**OpenRouter API Key** for Orion Kernel requests.\n\nGet a free key at [openrouter.ai/settings/keys](https://openrouter.ai/settings/keys).\n\nAll models — including Claude, GPT-4.1, Gemini and Llama — are accessible via a **single OpenRouter key**. No separate provider accounts needed.",
          "order": 1
        },
        "genesis.orion.model": {
          "type": "string",
          "default": "qwen/qwen3-235b-a22b:free",
          "enum": [
            "qwen/qwen3-235b-a22b:free",
            "qwen/qwen3-32b:free",
            "qwen/qwen3-30b-a3b:free",
            "qwen/qwen3-235b-a22b",
            "qwen/qwen-2.5-coder-32b",
            "qwen/qwen-2.5-coder-72b-instruct",
            "qwen/qwen-2.5-plus",
            "anthropic/claude-sonnet-4-5",
            "anthropic/claude-opus-4-5",
            "openai/gpt-4.1",
            "openai/gpt-4.1-mini",
            "google/gemini-2.5-pro",
            "google/gemini-2.5-flash",
            "meta-llama/llama-3.1-405b-instruct",
            "deepseek/deepseek-r1"
          ],
          "enumDescriptions": [
            "🆓 Qwen3 235B MoE – strongest free model (recommended for free tier)",
            "🆓 Qwen3 32B Dense – free, great for code",
            "🆓 Qwen3 30B MoE – fast and free",
            "💎 Qwen3 235B – no rate limits, full speed (paid)",
            "💎 Qwen2.5-Coder 32B – optimised for code (paid)",
            "💎 Qwen2.5-Coder 72B Instruct (paid)",
            "💎 Qwen2.5-Plus general purpose (paid)",
            "🏆 Claude Sonnet 4.5 – top SWE-bench performance (paid via OpenRouter)",
            "🏆 Claude Opus 4.5 – maximum reasoning depth (paid via OpenRouter)",
            "🏆 GPT-4.1 – OpenAI flagship, very strong for code (paid via OpenRouter)",
            "💎 GPT-4.1 Mini – fast and cheap, good for drafts (paid via OpenRouter)",
            "🏆 Gemini 2.5 Pro – 1M token context window (paid via OpenRouter)",
            "💎 Gemini 2.5 Flash – extremely fast and cheap (paid via OpenRouter)",
            "💎 Llama 3.1 405B – best open-source, cost-effective for batch tasks (paid via OpenRouter)",
            "💎 DeepSeek R1 – leading reasoning model, best price-performance ratio (paid via OpenRouter)"
          ],
          "markdownDescription": "**Orion Kernel model** via OpenRouter.\n\n- 🆓 `:free` models — no cost, rate-limited\n- 💎 Paid models — requires credits on [openrouter.ai](https://openrouter.ai)\n- 🏆 Top frontier models (Claude, GPT-4.1, Gemini) — best performance\n\nAll accessible with the **same single OpenRouter API key**.",
          "order": 2
        },
        "genesis.orion.selfConsistency": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Self-Consistency Probing** — derive real K confidence from response stability.\n\nWhen enabled, the K-Gate runs 3 parallel probes and measures response agreement to compute a genuine confidence score instead of synthetic estimates.\n\n⚠️ Uses 3× tokens per gated decision. Recommended only for high-stakes actions.",
          "order": 6
        },
        "genesis.orion.kThreshold": {
          "type": "number",
          "default": 3.2,
          "minimum": 1,
          "maximum": 5,
          "markdownDescription": "**K threshold** for deterministic reasoning gate.\n\nDecisions with K < threshold enter **ABSTAIN** mode (zero false positives).\n\nDefault: `3.2` (ORION sovereign threshold). Range: 1.0–5.0.",
          "order": 3
        },
        "genesis.orion.edgeMode": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Edge mode** — optimized for ~20W hardware.\n\nEnables: free-only models, 8K token limit, no streaming, no background refresh.\n\nIdeal for Raspberry Pi 5, Jetson Nano, or low-power laptops.",
          "order": 4
        },
        "genesis.orion.auditTrail": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Audit trail** — EU AI Act compliance (Article 13/14).\n\nLogs every decision with SHA-256 proof chain to `.orion/audit-trail.jsonl`.\n\nRequired for Article 13 transparency obligations (deadline: August 2026).",
          "order": 5
        }
      }
    }
  },
  "main": "./dist/extension.cjs",
  "type": "module",
  "scripts": {
    "prepackage": "node ./scripts/prepackage.js",
    "build": "npm run build:dev",
    "build:dev": "npm run check-types && npm run lint && node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "generate:notices": "node ./scripts/generate-notices.js",
    "prepare": "npm run generate:notices",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "watch": "npm-run-all2 -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "vsce package --no-dependencies",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "validate:notices": "node ./scripts/validate-notices.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "20.x",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "autoprefixer": "^10.4.22",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "npm-run-all2": "^8.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@qwen-code/webui": "*",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "markdown-it": "^14.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semver": "^7.7.2",
    "zod": "^3.25.76"
  }
}
